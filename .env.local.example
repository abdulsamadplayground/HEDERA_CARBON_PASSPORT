# Hedera Network Configuration
HEDERA_OPERATOR_ID=0.0.XXXXXXX
#HEDERA_OPERATOR_KEY=302e020100300506032b657004220420...
HEDERA_EVM_ADDRESS=0x_YOUR_EVM_ADDRESS_HERE
HEDERA_HEXCODED_KEY=0x_YOUR_HEX_PRIVATE_KEY_HERE
HEDERA_DER_PRIVATE=YOUR_DER_ENCODED_PRIVATE_KEY_HERE
HEDERA_DER_PUBLIC=YOUR_DER_ENCODED_PUBLIC_KEY_HERE
HEDERA_NETWORK=testnet

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/carbon_passport

# Mirror Node (optional, defaults to public testnet)
HEDERA_MIRROR_NODE_URL=https://testnet.mirrornode.hedera.com

# Redis (optional)
REDIS_URL=redis://localhost:6379

# Product Feed Configuration
CLIMATIQ_API_KEY=YOUR_CLIMATIQ_API_KEY_HERE
OPEN_FOOD_FACTS_BASE_URL=https://world.openfoodfacts.org
PRODUCT_FEED_POLL_INTERVAL_MS=60000

# Hedera Guardian (optional — leave empty to use built-in local policy engine)
# Deploy Guardian via Docker: docker compose -f ./deploy/docker-compose.yml --profile all up -d
# Guardian docs: https://docs.hedera.com/guardian
#
# GUARDIAN_API_URL=http://localhost:3000/api/v1
# GUARDIAN_SR_USERNAME=StandardRegistry
# GUARDIAN_SR_PASSWORD=test
# GUARDIAN_VVB_USERNAME=VVB
# GUARDIAN_VVB_PASSWORD=test
# GUARDIAN_USER_USERNAME=ProjectProponent
# GUARDIAN_USER_PASSWORD=test
# GUARDIAN_POLICY_MESSAGE_ID=
